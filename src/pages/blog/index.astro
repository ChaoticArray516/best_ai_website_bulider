---
// Blog index page - SEO-optimized listing of all blog posts
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Fetch and sort all blog posts by publication date (newest first)
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.datePublished.valueOf() - a.data.datePublished.valueOf());
---

<BaseLayout
  title="AI Website Builder Blog — Tips, Reviews & Guides [2025]"
  description="Expert guides on AI website builders, vibe coding, and web development. Updated monthly by our editorial team."
>
  <section class="max-w-4xl mx-auto px-4 py-12">
    <!-- Breadcrumb navigation for SEO -->
    <nav class="text-sm text-gray-500 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-blue-600">Home</a>
      <span class="mx-2">→</span>
      <span class="text-gray-900">Blog</span>
    </nav>

    <!-- Page header with SEO-optimized title -->
    <h1 class="text-4xl font-extrabold text-gray-900 mb-3">Blog</h1>
    <p class="text-lg text-gray-600 mb-10">
      Expert guides on AI website builders, vibe coding, and web development.
    </p>

    <!-- Blog posts list -->
    <div class="space-y-6">
      {posts.map(post => (
        <article class="bg-white border border-gray-200 rounded-xl p-6 hover:border-blue-200 hover:shadow-md transition-all">
          <!-- Post metadata: author and date -->
          <div class="flex items-center gap-3 text-xs text-gray-500 mb-2">
            <span>{post.data.author}</span>
            <span>·</span>
            <time datetime={post.data.datePublished.toISOString()}>
              {post.data.datePublished.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          <!-- Post title with link -->
          <h2 class="text-xl font-bold text-gray-900 mb-2">
            <a href={`/blog/${post.id}/`} class="hover:text-blue-600 transition-colors">
              {post.data.title}
            </a>
          </h2>
          <!-- Post description -->
          <p class="text-gray-600 text-sm leading-relaxed mb-4">{post.data.description}</p>
          <!-- Read more link -->
          <a href={`/blog/${post.id}/`} class="text-sm font-semibold text-blue-600 hover:underline">
            Read article →
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
