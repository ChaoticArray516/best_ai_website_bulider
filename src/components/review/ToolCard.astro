---
// ToolCard Component - Displays AI tool information with technical badges
import type { CollectionEntry } from 'astro:content';
import AffiliateBtn from '../AffiliateBtn.astro';
import RatingStars  from './RatingStars.astro';

interface Props {
  tool:  CollectionEntry<'tools'>;
  rank?: number;
}

const { tool, rank } = Astro.props;
const {
  name, tagline, rating, price, pros, bestFor,
  affiliateLink, featured,
  exportFormats, hasApi, communitySize,   // New fields from Step 2 schema extension
} = tool.data;

// Determine if any technical badge should be displayed
const showBadges = hasApi || (exportFormats && exportFormats.length > 0) || (communitySize && communitySize >= 1000);
---

<article class={`
  relative bg-white border rounded-xl p-6
  hover:shadow-lg hover:border-blue-200 transition-all duration-300
  ${featured ? 'border-blue-300 ring-2 ring-blue-100' : 'border-gray-200'}
`}>

  <!-- Featured Badge -->
  {featured && (
    <span class="absolute -top-3 left-6 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded-full">
      ⭐ Editor's Choice
    </span>
  )}

  <!-- Header Row -->
  <div class="flex items-start justify-between gap-4 mb-5">
    <div class="flex items-center gap-3">
      {rank && (
        <span class="text-3xl font-extrabold text-blue-600 leading-none">#{rank}</span>
      )}
      <div>
        <h3 class="text-xl font-bold text-gray-900">{name}</h3>
        <p class="text-sm text-gray-600 mt-0.5">{tagline}</p>
      </div>
    </div>
    <div class="text-right shrink-0">
      <div class="text-2xl font-extrabold text-amber-500">{rating}<span class="text-sm text-gray-400 font-normal">/5</span></div>
      <RatingStars rating={rating} />
      <p class="text-xs text-gray-500 mt-1">
        {price.freePlan ? '✓ Free plan' : `From $${price.startingPrice}/mo`}
      </p>
    </div>
  </div>

  <!-- Pros -->
  <div class="mb-4">
    <ul class="space-y-1.5">
      {pros.map(pro => (
        <li class="flex items-start gap-2 text-sm text-gray-700">
          <span class="text-green-500 font-bold mt-0.5 shrink-0">✓</span>
          {pro}
        </li>
      ))}
    </ul>
  </div>

  <!-- Technical Badges (new in Step 3) -->
  {showBadges && (
    <div class="flex flex-wrap gap-2 mb-4">
      {hasApi && (
        <span class="bg-purple-50 text-purple-700 text-xs font-semibold px-2.5 py-1 rounded-md border border-purple-200">
          🔌 API Available
        </span>
      )}
      {exportFormats && exportFormats.length > 0 && (
        <span class="bg-blue-50 text-blue-700 text-xs font-semibold px-2.5 py-1 rounded-md border border-blue-200">
          📦 Exports: {exportFormats.join(', ')}
        </span>
      )}
      {communitySize && communitySize >= 1000 && (
        <span class="bg-green-50 text-green-700 text-xs font-semibold px-2.5 py-1 rounded-md border border-green-200">
          👥 {communitySize.toLocaleString()} saves
        </span>
      )}
    </div>
  )}

  <!-- Best For -->
  <p class="text-xs text-gray-500 mb-5">
    <span class="font-semibold text-gray-700">Best for:</span> {bestFor}
  </p>

  <!-- CTA Row -->
  <div class="flex items-center gap-3">
    <AffiliateBtn link={affiliateLink} text={`Visit ${name}`} variant="primary" />
    <a href={`/review/${tool.data.slug}/`} class="text-sm text-blue-600 hover:text-blue-700 hover:underline font-medium">
      Read full review →
    </a>
  </div>

</article>
