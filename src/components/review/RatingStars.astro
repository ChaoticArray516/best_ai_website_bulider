---
interface Props {
  rating: number;
  max?:   number;
}
const { rating, max = 5 } = Astro.props;
const fullStars  = Math.floor(rating);
const hasHalf    = rating % 1 >= 0.5;
const emptyStars = max - fullStars - (hasHalf ? 1 : 0);
---

<div class="flex items-center gap-0.5" aria-label={`Rating: ${rating} out of ${max}`}>
  {Array(fullStars).fill(null).map(() => (
    <svg class="w-4 h-4 text-amber-500 fill-current" viewBox="0 0 20 20">
      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
    </svg>
  ))}
  {hasHalf && (
    <svg class="w-4 h-4 text-amber-500" viewBox="0 0 20 20">
      <defs>
        <linearGradient id="half">
          <stop offset="50%" stop-color="rgb(245,158,11)"/>
          <stop offset="50%" stop-color="rgb(229,231,235)"/>
        </linearGradient>
      </defs>
      <path fill="url(#half)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
    </svg>
  )}
  {Array(emptyStars).fill(null).map(() => (
    <svg class="w-4 h-4 text-gray-200 fill-current" viewBox="0 0 20 20">
      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
    </svg>
  ))}
  <span class="ml-1 text-sm font-semibold text-gray-700">{rating}</span>
</div>
